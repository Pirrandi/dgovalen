---
import '../styles/global.css';
import { t, getLangFromUrl, getOtherLang, localePath, type Lang } from '../i18n';

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
}

const { title = 'dgovalen', description = 'Security researcher. CVEs, HTB writeups, research.', lang: langProp } = Astro.props;
const lang: Lang = langProp ?? getLangFromUrl(new URL(Astro.request.url));
const otherLang = getOtherLang(lang);
const fullTitle = title === 'dgovalen' ? title : `${title} · dgovalen`;

const currentPath = new URL(Astro.request.url).pathname;
const alternatePath = lang === 'es'
  ? `/en${currentPath === '/' ? '' : currentPath}`
  : currentPath.replace(/^\/en/, '') || '/';

const siteURL = Astro.site ?? new URL('https://dgovalen.vercel.app');
const canonicalURL = new URL(currentPath, siteURL).href;
const ogImageURL = new URL('/og.png', siteURL).href;
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <meta name="generator" content={Astro.generator} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate" hreflang={otherLang} href={alternatePath} />
  <link rel="alternate" type="application/rss+xml" title="dgovalen" href="/rss.xml" />
  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:site_name" content="dgovalen" />
  <meta property="og:image" content={ogImageURL} />
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />
  <title>{fullTitle}</title>
</head>
<body>
  <nav class="nav">
    <div class="container nav-inner">
      <a href={localePath(lang, '/')} class="nav-brand">dgovalen</a>
      <ul class="nav-links">
        <li><a href={localePath(lang, '/blog')}>{t(lang, 'nav.blog')}</a></li>
        <li><a href={localePath(lang, '/htb')}>{t(lang, 'nav.htb')}</a></li>
        <li><a href={localePath(lang, '/cves')}>{t(lang, 'nav.cves')}</a></li>
        <li><a href={localePath(lang, '/research')}>{t(lang, 'nav.research')}</a></li>
        <li class="lang-sep">|</li>
        <li><a href={alternatePath} class="lang-switch">{otherLang.toUpperCase()}</a></li>
      </ul>
    </div>
  </nav>

  <main class="main">
    <div class="container">
      <slot />
    </div>
  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <span class="text-muted">Diego Valencia &copy; {new Date().getFullYear()}</span>
      <span class="text-muted"><a href="https://github.com/Pirrandi" target="_blank" rel="noopener">{t(lang, 'footer.github')}</a></span>
    </div>
  </footer>
</body>
</html>

<style>
.nav {
  border-bottom: 1px solid var(--bg-border);
  position: sticky;
  top: 0;
  background: rgba(13,11,20,0.96);
  backdrop-filter: blur(6px);
  z-index: 100;
}

.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 0.9rem;
  padding-bottom: 0.9rem;
  gap: 1rem;
}

.nav-brand {
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--purple-soft);
  text-decoration: none;
  white-space: nowrap;
  letter-spacing: 0.03em;
}

.nav-brand:hover { color: var(--purple-soft); text-decoration: none; }

.nav-links {
  display: flex;
  list-style: none;
  padding: 0;
  margin: 0;
  gap: 1.6rem;
  flex-wrap: wrap;
  align-items: center;
}

.nav-links a {
  color: var(--text-muted);
  font-size: 0.82rem;
  text-decoration: none;
  transition: color 0.15s;
}

.nav-links a:hover { color: var(--purple-soft); text-decoration: none; }

.lang-sep { color: var(--bg-border); font-size: 0.8rem; user-select: none; }

.lang-switch {
  font-size: 0.72rem !important;
  font-weight: 700;
  letter-spacing: 0.08em;
  color: var(--text-muted) !important;
  border: 1px solid var(--bg-border);
  padding: 2px 7px;
  border-radius: 3px;
  transition: all 0.15s !important;
}

.lang-switch:hover {
  color: var(--purple-soft) !important;
  border-color: var(--purple-dim) !important;
  text-decoration: none !important;
}

.main {
  padding: 3rem 0;
  min-height: calc(100vh - 110px);
}

.footer {
  border-top: 1px solid var(--bg-border);
  padding: 1.5rem 0;
}

.footer-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 0.78rem;
}

.text-muted { color: var(--text-muted); }

@media (max-width: 600px) {
  .nav-inner { flex-direction: column; align-items: flex-start; }
  .nav-links { gap: 1rem; }
}
</style>
