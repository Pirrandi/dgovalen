---
import Base from '../layouts/Base.astro';
---
<Base title="404" description="Página no encontrada">
  <div class="notfound">
    <p class="code">404</p>
    <p class="msg">Esta página no existe o fue movida.</p>
    <a href="/" class="back">← volver al inicio</a>
  </div>
</Base>

<style>
.notfound {
  padding: 5rem 0;
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
}
.code {
  font-size: 4rem;
  font-weight: 700;
  color: var(--purple-soft);
  margin: 0;
  line-height: 1;
}
.msg {
  color: var(--text-muted);
  font-size: 0.95rem;
  margin: 0;
}
.back {
  color: var(--text-muted);
  font-size: 0.85rem;
  text-decoration: none;
  margin-top: 0.5rem;
}
.back:hover { color: var(--purple-soft); }
</style>
