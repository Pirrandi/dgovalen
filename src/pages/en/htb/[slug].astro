---
import Post from '../../../layouts/Post.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const machines = await getCollection('htb', e => !e.data.draft);
  return machines.map(m => ({ params: { slug: m.id }, props: { machine: m } }));
}

const { machine } = Astro.props;
const { Content } = await render(machine);
const diffColor = { Easy: 'tag-green', Medium: 'tag-amber', Hard: 'tag-red', Insane: 'tag-purple' } as const;
---
<Post
  title={machine.data.title}
  description={machine.data.description}
  date={machine.data.date}
  tags={[machine.data.os, ...machine.data.tags]}
  badge={machine.data.difficulty}
  badgeColor={diffColor[machine.data.difficulty]}
  lang="en"
  ogImage={`/og/htb/${machine.id}.png`}
>
  <Content />
</Post>
