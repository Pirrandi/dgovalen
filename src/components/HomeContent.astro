---
import { getCollection } from 'astro:content';
import { t, localePath, type Lang } from '../i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;

const posts    = (await getCollection('blog',     e => !e.data.draft)).sort((a,b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0,3);
const htb      = (await getCollection('htb',      e => !e.data.draft)).sort((a,b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0,3);
const cves     = (await getCollection('cves',     e => !e.data.draft)).sort((a,b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0,3);
const research = (await getCollection('research', e => !e.data.draft)).sort((a,b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0,3);

const diffColor = { Easy: 'tag-green', Medium: 'tag-amber', Hard: 'tag-red', Insane: 'tag-purple' } as const;
const sevColor  = { Critical: 'tag-red', High: 'tag-red', Medium: 'tag-amber', Low: 'tag-green', Informational: 'tag-cyan' } as const;
---

<!-- HERO -->
<section class="hero">
  <div class="hero-profile">
    <img
      src="https://avatars.githubusercontent.com/u/39172875?v=4"
      alt="Diego Valencia"
      class="avatar"
      width="72"
      height="72"
    />
    <div class="hero-info">
      <h1 class="hero-name">Diego Valencia</h1>
      <p class="hero-handle">
        <span class="muted">~/</span>dgovalen
        <span class="sep">·</span>
        <a href="https://github.com/Pirrandi" target="_blank" rel="noopener" class="gh-link">@Pirrandi</a>
        <span class="sep">·</span>
        <span class="muted">{t(lang, 'hero.location')}</span>
      </p>
      <p class="hero-bio">{t(lang, 'hero.bio')}<span class="cursor"></span></p>
    </div>
  </div>

  <div class="certs">
    <span class="certs-label">{t(lang, 'certs.label')}</span>
    <div class="certs-list">
      <span class="cert">eJPT</span>
      <span class="cert">eWPTX</span>
      <span class="cert">ICCA</span>
      <span class="cert cert-wip">BSCP <span class="wip-badge">{t(lang, 'certs.wip')}</span></span>
    </div>
  </div>
</section>

<!-- BLOG -->
{posts.length > 0 && (
  <section class="section">
    <div class="section-header">
      <h2 class="section-title">{t(lang, 'section.blog')}</h2>
      <a href={localePath(lang, '/blog')} class="section-more">{t(lang, 'section.seeAll')}</a>
    </div>
    <ul class="card-list">
      {posts.map(p => (
        <li class="card">
          <div class="card-meta">
            <span class="card-date">{p.data.date.toISOString().split('T')[0]}</span>
            {p.data.tags.slice(0,3).map(tag => <span class="tag tag-purple">{tag}</span>)}
          </div>
          <a href={`/blog/${p.id}`} class="card-title">{p.data.title}</a>
          <p class="card-desc">{p.data.description}</p>
        </li>
      ))}
    </ul>
  </section>
)}

<!-- HTB -->
{htb.length > 0 && (
  <section class="section">
    <div class="section-header">
      <h2 class="section-title">{t(lang, 'section.htb')}</h2>
      <a href={localePath(lang, '/htb')} class="section-more">{t(lang, 'section.seeAll')}</a>
    </div>
    <ul class="card-list">
      {htb.map(p => (
        <li class="card">
          <div class="card-meta">
            <span class="card-date">{p.data.date.toISOString().split('T')[0]}</span>
            <span class={`tag ${diffColor[p.data.difficulty]}`}>{p.data.difficulty}</span>
            <span class="tag tag-cyan">{p.data.os}</span>
          </div>
          <a href={`/htb/${p.id}`} class="card-title">{p.data.title}</a>
          <p class="card-desc">{p.data.description}</p>
        </li>
      ))}
    </ul>
  </section>
)}

<!-- CVES -->
{cves.length > 0 && (
  <section class="section">
    <div class="section-header">
      <h2 class="section-title">{t(lang, 'section.cves')}</h2>
      <a href={localePath(lang, '/cves')} class="section-more">{t(lang, 'section.seeAll')}</a>
    </div>
    <ul class="card-list">
      {cves.map(p => (
        <li class="card card-cve">
          <div class="card-meta">
            <span class="card-date">{p.data.date.toISOString().split('T')[0]}</span>
            <span class={`tag ${sevColor[p.data.severity]}`}>{p.data.severity}</span>
            {p.data.cvss && <span class="tag tag-amber">CVSS {p.data.cvss}</span>}
          </div>
          <a href={`/cves/${p.id}`} class="card-title">
            <span class="cve-id">{p.data.cve_id}</span> — {p.data.title}
          </a>
          <p class="card-desc">{p.data.description}</p>
        </li>
      ))}
    </ul>
  </section>
)}

<!-- RESEARCH -->
{research.length > 0 && (
  <section class="section">
    <div class="section-header">
      <h2 class="section-title">{t(lang, 'section.research')}</h2>
      <a href={localePath(lang, '/research')} class="section-more">{t(lang, 'section.seeAll')}</a>
    </div>
    <ul class="card-list">
      {research.map(p => (
        <li class="card">
          <div class="card-meta">
            <span class="card-date">{p.data.date.toISOString().split('T')[0]}</span>
            {p.data.tags.slice(0,3).map(tag => <span class="tag tag-indigo">{tag}</span>)}
          </div>
          <a href={`/research/${p.id}`} class="card-title">{p.data.title}</a>
          <p class="card-desc">{p.data.description}</p>
        </li>
      ))}
    </ul>
  </section>
)}

<style>
.hero { padding: 2rem 0 1rem; margin-bottom: 1.5rem; }

.hero-profile { display: flex; align-items: center; gap: 1.2rem; margin-bottom: 1.2rem; }

.avatar { width: 72px; height: 72px; border-radius: 50%; flex-shrink: 0; }

.hero-name { font-size: 1.4rem; margin-bottom: 0.15rem; color: var(--text); font-weight: 700; }

.hero-handle { font-size: 0.82rem; color: var(--text-muted); margin-bottom: 0.3rem; }
.hero-handle .sep { margin: 0 0.4rem; }

.gh-link { color: var(--indigo); text-decoration: none; }
.gh-link:hover { color: var(--purple-soft); text-decoration: none; }

.hero-bio { font-size: 0.9rem; color: var(--text-muted); margin: 0; }

.muted { color: var(--text-muted); }

.certs { display: flex; align-items: center; gap: 0.8rem; margin-top: 1.2rem; flex-wrap: wrap; }
.certs-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); white-space: nowrap; }
.certs-list { display: flex; flex-wrap: wrap; gap: 0.5rem; }

.cert {
  font-size: 0.78rem; font-weight: 600; padding: 3px 10px; border-radius: 4px;
  background: #1e1535; border: 1px solid var(--purple-dim); color: var(--purple-soft);
  display: flex; align-items: center; gap: 0.4rem;
}
.cert-wip { border-color: #4a3a6a; color: #8b6fc0; }
.wip-badge { font-size: 0.62rem; background: #2d1f4a; color: var(--text-muted); padding: 1px 5px; border-radius: 3px; font-weight: 400; }

.section { margin-bottom: 2.5rem; }
.section-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 0.6rem; }
.section-title { font-size: 0.72rem; color: var(--purple-dim); text-transform: uppercase; letter-spacing: 0.12em; font-weight: 700; }
.section-more { font-size: 0.75rem; color: var(--text-muted); text-decoration: none; }
.section-more:hover { color: var(--purple-soft); text-decoration: none; }

.card-list { list-style: none; padding: 0; }
.card { padding: 0.7rem 0.8rem; border-radius: 6px; margin-bottom: 0.2rem; }
.card:hover { background: var(--bg-card); }

.card-meta { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.25rem; }
.card-date { color: var(--text-muted); font-size: 0.72rem; }

.card-title { display: block; color: var(--text); font-size: 0.92rem; font-weight: 600; text-decoration: none; margin-bottom: 0.15rem; transition: color 0.15s; }
.card-title:hover { color: var(--purple-soft); text-decoration: none; }

.card-desc { color: var(--text-muted); font-size: 0.8rem; margin: 0; }
.cve-id { color: var(--red); font-weight: 700; }
.card-cve .card-title:hover { color: var(--red); }

@media (max-width: 500px) { .certs { flex-direction: column; align-items: flex-start; } }
</style>
